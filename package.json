{
  "name": "wordpress-parser",
  "version": "0.1.0",
  "description": "Generate a reusable skill.md and optional RAG JSON from WordPress content.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "mcp:wp": "node mcp/server.js",
    "check": "node --check server.js",
    "test:smoke": "node scripts/api-smoke.mjs",
    "profile:list": "node node_tools/version_manager.js list",
    "profile:backup": "node node_tools/version_manager.js backup",
    "profile:rollback": "node node_tools/version_manager.js rollback",
    "profile:assemble": "node node_tools/skill_writer.js",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.3",
    "express": "^4.21.2",
    "fast-xml-parser": "^5.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0"
  }
}
